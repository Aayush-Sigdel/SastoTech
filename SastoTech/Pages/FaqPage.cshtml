@page
@model SastoTech.Pages.FaqPage

@{
    ViewData["Title"] = "Frequently Asked Questions";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-800">Support Center</h1>
        <p class="text-muted fs-5">Everything you need to know about SastoTech.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="accordion accordion-flush custom-accordion" id="faqAccordion">
                <div class="accordion-item border-0 shadow-none mb-3 overflow-hidden">
                    <h2 class="accordion-header" id="headingWhatIs">
                        <button class="accordion-button collapsed fw-bold py-4 px-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseWhatIs" aria-expanded="false" aria-controls="collapseWhatIs">
                            What is SastoTech?
                        </button>
                    </h2>
                    <div id="collapseWhatIs" class="accordion-collapse collapse" aria-labelledby="headingWhatIs" data-bs-parent="#faqAccordion">
                        <div class="accordion-body px-4 pb-4 text-muted">
                            SastoTech is this website! We are based in Nepal and our goal is to help you save money by finding and sharing the best deals on laptops and mobiles from various trusted retailers and stores across the country.
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-0 shadow-none mb-3 overflow-hidden">
                    <h2 class="accordion-header" id="headingHowFind">
                        <button class="accordion-button collapsed fw-bold py-4 px-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseHowFind" aria-expanded="false" aria-controls="collapseHowFind">
                            How does SastoTech find deals?
                        </button>
                    </h2>
                    <div id="collapseHowFind" class="accordion-collapse collapse" aria-labelledby="headingHowFind" data-bs-parent="#faqAccordion">
                        <div class="accordion-body px-4 pb-4 text-muted">
                            We manually track prices from trusted retailers in Nepal and only share discounts we believe are genuine, high-value deals.
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-0 shadow-none mb-3 overflow-hidden">
                    <h2 class="accordion-header" id="headingDifferent">
                        <button class="accordion-button collapsed fw-bold py-4 px-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDifferent" aria-expanded="false" aria-controls="collapseDifferent">
                            What makes SastoTech different?
                        </button>
                    </h2>
                    <div id="collapseDifferent" class="accordion-collapse collapse" aria-labelledby="headingDifferent" data-bs-parent="#faqAccordion">
                        <div class="accordion-body px-4 pb-4 text-muted">
                            Many "deal websites" post every single discount regardless of quality. We use our expertise to curate only the best options. Since we track historical price data, we know if a deal is actually good or if it's just a retailer trick of increasing the price before a "sale".
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-0 shadow-none mb-3 overflow-hidden">
                    <h2 class="accordion-header" id="headingFrequency">
                        <button class="accordion-button collapsed fw-bold py-4 px-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFrequency" aria-expanded="false" aria-controls="collapseFrequency">
                            How often are deals updated?
                        </button>
                    </h2>
                    <div id="collapseFrequency" class="accordion-collapse collapse" aria-labelledby="headingFrequency" data-bs-parent="#faqAccordion">
                        <div class="accordion-body px-4 pb-4 text-muted">
                            The site is updated multiple times a day to ensure you never miss the latest sales in the Nepalese market.
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-0 shadow-none mb-3 overflow-hidden">
                    <h2 class="accordion-header" id="headingBuyDirect">
                        <button class="accordion-button collapsed fw-bold py-4 px-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseBuyDirect" aria-expanded="false" aria-controls="collapseBuyDirect">
                            Can I buy products directly from SastoTech?
                        </button>
                    </h2>
                    <div id="collapseBuyDirect" class="accordion-collapse collapse" aria-labelledby="headingBuyDirect" data-bs-parent="#faqAccordion">
                        <div class="accordion-body px-4 pb-4 text-muted">
                            No, we do not sell devices ourselves. We find the best prices from other sites and stores and show them here. When you click to buy, you will be redirected to the retailer's website or store.
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-0 shadow-none mb-3 overflow-hidden">
                    <h2 class="accordion-header" id="headingAffiliated">
                        <button class="accordion-button collapsed fw-bold py-4 px-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAffiliated" aria-expanded="false" aria-controls="collapseAffiliated">
                            Is SastoTech affiliated with retailers?
                        </button>
                    </h2>
                    <div id="collapseAffiliated" class="accordion-collapse collapse" aria-labelledby="headingAffiliated" data-bs-parent="#faqAccordion">
                        <div class="accordion-body px-4 pb-4 text-muted">
                            We may earn a small commission from purchases made through our links, but this doesn’t affect the deals we share. We prioritize your savings over our commissions. If we find a cheaper deal from a retailer we aren't affiliated with, we will still list it.
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-0 shadow-none mb-3 overflow-hidden">
                    <h2 class="accordion-header" id="headingTrust">
                        <button class="accordion-button collapsed fw-bold py-4 px-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTrust" aria-expanded="false" aria-controls="collapseTrust">
                            Can I trust the deals shared here?
                        </button>
                    </h2>
                    <div id="collapseTrust" class="accordion-collapse collapse" aria-labelledby="headingTrust" data-bs-parent="#faqAccordion">
                        <div class="accordion-body px-4 pb-4 text-muted">
                            Yes! We only link to reputable retailers in Nepal. We have blacklisted a number of sellers based on community feedback to ensure your safety and satisfaction.
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-0 shadow-none mb-3 overflow-hidden">
                    <h2 class="accordion-header" id="headingRecordLow">
                        <button class="accordion-button collapsed fw-bold py-4 px-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseRecordLow" aria-expanded="false" aria-controls="collapseRecordLow">
                            How do you know if a deal is a "Record Low Price"?
                        </button>
                    </h2>
                    <div id="collapseRecordLow" class="accordion-collapse collapse" aria-labelledby="headingRecordLow" data-bs-parent="#faqAccordion">
                        <div class="accordion-body px-4 pb-4 text-muted">
                            We keep track of prices internally for different models and specs. We only apply the "Record Low Price" tag if we are confident based on our long-term data for the Nepalese market.
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <p class="text-muted">Have you found a tech deal you want to share? Submit it to <a href="mailto:deals@SastoTech.com" class="text-dark fw-bold text-decoration-underline">deals@SastoTech.com</a></p>
                <p class="text-muted mt-2 small">For other inquiries, you can <a href="https://github.com/Aayush-Sigdel" class="text-dark fw-bold text-decoration-underline">Contact our team</a></p>
            </div>
        </div>
    </div>
</div>