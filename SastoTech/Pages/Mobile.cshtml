@page
@model SastoTech.Pages.Mobile

@{
ViewData["Title"] = "Mobile";
}

<div class="container py-4">
  <div class="text-center mb-5">
    <h1 class="display-4 fw-800">Latest Mobiles</h1>
    <p class="text-muted fs-5">Cutting-edge technology in the palm of your hand.</p>
  </div>

  <div class="row">
    <div class="col-12 d-lg-none mb-3">
      <button class="btn btn-primary w-100 d-flex justify-content-between align-items-center py-3 shadow-none"
        type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="false">
        <span class="fw-bold text-uppercase small letter-spacing-1"><i class="bi bi-filter-left fs-5 me-2"></i>
          Filters</span>
        <i class="bi bi-chevron-down transition-transform"></i>
      </button>
    </div>

    <div class="col-lg-3 mb-4">
      <div id="filterCollapse" class="collapse d-lg-block sticky-sidebar">
        <div class="card border-0 card-filter">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-4 d-none d-lg-flex align-items-center">
              <i class="bi bi-filter-left me-2"></i> Filters
            </h2>
            <form method="get">
              <div class="mb-3">
                <label class="small fw-bold text-muted mb-2 text-uppercase letter-spacing-1">Search</label>
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-search text-muted"></i></span>
                  <input type="text" name="SearchString" value="@Model.SearchString" class="form-control"
                    placeholder="Search products...">
                </div>
              </div>

              <div class="mb-3">
                <label class="small fw-bold text-muted mb-2 text-uppercase letter-spacing-1">Category</label>
                <select name="Category" class="form-select">
                  <option value="">All Categories</option>
                  @foreach (var cat in Model.CategoryList)
                  {
                  <option value="@cat" selected="@(cat == Model.Category)">@cat</option>
                  }
                </select>
              </div>

              <div class="mb-3">
                <label class="small fw-bold text-muted mb-2 text-uppercase letter-spacing-1">Brand</label>
                <select name="Brand" class="form-select">
                  <option value="">All Brands</option>
                  @foreach (var brand in Model.BrandList)
                  {
                  <option value="@brand" selected="@(brand == Model.Brand)">@brand</option>
                  }
                </select>
              </div>

              <div class="mb-3">
                <label class="small fw-bold text-muted mb-2 text-uppercase letter-spacing-1">Price Range</label>
                <div class="row g-2">
                  <div class="col-6">
                    <input type="number" step="0.01" name="MinPrice" value="@Model.MinPrice" class="form-control"
                      placeholder="Min">
                  </div>
                  <div class="col-6">
                    <input type="number" step="0.01" name="MaxPrice" value="@Model.MaxPrice" class="form-control"
                      placeholder="Max">
                  </div>
                </div>
              </div>

              <div class="mb-3">
                <label class="small fw-bold text-muted mb-2 text-uppercase letter-spacing-1">Processor</label>
                <select name="Processor" class="form-select">
                  <option value="">All Processors</option>
                  @foreach (var proc in Model.ProcessorList)
                  {
                  <option value="@proc" selected="@(proc == Model.Processor)">@proc</option>
                  }
                </select>
              </div>

              <div class="mb-4">
                <label class="small fw-bold text-muted mb-2 text-uppercase letter-spacing-1">Screen Size</label>
                <select name="ScreenSize" class="form-select">
                  <option value="">All Sizes</option>
                  @foreach (var size in Model.ScreenSizeList)
                  {
                  <option value="@size" selected="@(size == Model.ScreenSize)">@size</option>
                  }
                </select>
              </div>

              <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary py-2 fw-bold">Apply Filters</button>
                <a asp-page="/Mobile" class="btn btn-outline-secondary py-2 small fw-bold">Clear All</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-9">
      <div class="row g-4">
        @foreach (var item in Model.MobilesList)
        {
        <div class="col-md-6 col-xl-4">
          <div class="card h-100 border-0 shadow-none product-card">
            <div class="position-relative">
              <div class="overflow-hidden">
                <img src="@item.Image" class="card-img-top rounded-0" alt="@item.Name"
                  style="height: 250px; object-fit: cover;">
              </div>
              @if (item.IsRecordLow)
              {
              <span class="badge-record-low position-absolute top-0 start-0 m-2 shadow-none">Best Price</span>
              }
              @if (item.DiscountPercentage > 0)
              {
              <span
                class="badge-discount position-absolute top-0 end-0 m-2 shadow-none">-@item.DiscountPercentage%</span>
              }
            </div>
            <div class="card-body p-4">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="brand-tag d-flex gap-1 flex-wrap">
                  <span class="badge bg-light text-dark border">@item.Brand</span>
                  @if (!string.IsNullOrEmpty(item.Category))
                  {
                  <span class="badge bg-dark-subtle text-dark border">@item.Category</span>
                  }
                </div>
                <div class="text-end">
                  @if (item.DiscountPercentage > 0)
                  {
                  <div class="price-original">Rs.@item.ActualPrice</div>
                  <div class="price-discounted">Rs.@item.DiscountedPrice</div>
                  <div class="save-amount">Save Rs.@(item.ActualPrice - item.DiscountedPrice)</div>
                  }
                  else
                  {
                  <div class="price-discounted text-dark" style="color: #262626 !important;">Rs.@item.ActualPrice</div>
                  }
                </div>
              </div>
              <h3 class="h5 card-title fw-bold mb-2">@item.Name</h3>
              <p class="card-text text-muted small mb-3">@item.Description</p>

              <div class="specs-grid">
                <div class="row g-2">
                  <div class="col-6">
                    <div class="specs-item">
                      <span class="specs-label">Disp</span>
                      <span class="specs-value">@item.ScreenSize</span>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="specs-item">
                      <span class="specs-label">Batt</span>
                      <span class="specs-value">@item.Battery</span>
                    </div>
                  </div>
                  <div class="col-12">
                    <div class="specs-item">
                      <span class="specs-label" style="width: 55px;">Cam</span>
                      <span class="specs-value" title="@item.Camera">@item.Camera</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="mt-4">
                <a href="@item.AffilitedUrl" class="btn btn-minimal w-100">View Details</a>
              </div>
            </div>
          </div>
        </div>
        }
        @if (!Model.MobilesList.Any())
        {
        <div class="col-12 text-center py-5">
          <p class="text-muted">No mobiles found matching your criteria.</p>
        </div>
        }
      </div>
    </div>

    <div class="col-12 mt-5">
      <div class="card border-0 bg-white p-5 rounded-md shadow-sm product-card text-center">
        <h3 class="fw-bold mb-3 text-main">Have you found a mobile deal you want to share?</h3>
        <p class="mb-4 text-muted">Help the Nepalese community save money by sharing the best deals you find.</p>
        <div class="d-flex justify-content-center">
          <a href="mailto:deals@SastoTech.com" class="btn btn-primary px-4 py-2 fw-bold">Submit it to
            deals@SastoTech.com</a>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
  $(document).ready(function () {
    const $form = $('form');
    const $inputs = $form.find('input, select');
    const $searchString = $('input[name="SearchString"]');
    let timeout = null;

    const searchValue = $searchString.val();
    if (searchValue) {
      $searchString.focus();
      $searchString[0].setSelectionRange(searchValue.length, searchValue.length);
    }

    $inputs.on('input change', function (e) {
      clearTimeout(timeout);
      timeout = setTimeout(function () {
        $form.submit();
      }, 500);
    });
  });
</script>
}
